{
  "name": "my-tomato-clock",
  "version": "1.1.2",
  "description": "tomatoclock",
  "main": "main.js",
  "author": "samspend",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "pack": "electron-builder --dir",
    "build:android": "electron-builder --build --android"
  },
  "author": "samspend",
  "devDependencies": {
    "electron": "v38.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourcompany.yourapp",
    "productName": "专注果园",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "pet.html",
      "assests/**/*",
      "images/**/*",
      "node_modules/**/*"
    ],
    "win": {
